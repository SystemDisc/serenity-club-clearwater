{
  "services": {
    "web": {
      "root": ".",
      "framework": "nextjs",
      "bindings": [
        {
          "type": "service",
          "service": "docx-converter",
          "format": "url",
          "env": "DOCX_CONVERTER_URL"
        }
      ]
    },
    "docx-converter": {
      "root": "services/docx-converter",
      "runtime": "container",
      "entrypoint": "Dockerfile.vercel"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "service": "web"
      }
    }
  ]
}
